# Copy to .env and fill in values — never commit .env to version control

# ── Platform selection ────────────────────────────────────────────────────────
# One of: nvidia_a100 | amd_mi250x | intel_pvc
PLATFORM=nvidia_a100

# ── NVIDIA / CUDA ─────────────────────────────────────────────────────────────
CUDA_HOME=/usr/local/cuda
CUDA_VISIBLE_DEVICES=0

# ── AMD / ROCm ────────────────────────────────────────────────────────────────
ROCM_HOME=/opt/rocm
HIP_VISIBLE_DEVICES=0

# ── Intel / oneAPI ────────────────────────────────────────────────────────────
ONEAPI_ROOT=/opt/intel/oneapi
# source ${ONEAPI_ROOT}/setvars.sh before running Intel experiments

# ── Framework roots (set after building from source) ─────────────────────────
KOKKOS_ROOT=/opt/kokkos
RAJA_ROOT=/opt/raja

# ── Benchmark suite roots (after cloning) ────────────────────────────────────
BABELSTREAM_ROOT=benchmarks/stream/BabelStream
RAJAPERF_ROOT=benchmarks/dgemm/RAJAPerf
GAP_ROOT=benchmarks/bfs/GAP
COMD_ROOT=benchmarks/nbody/CoMD

# ── Results storage ───────────────────────────────────────────────────────────
RESULTS_ROOT=results
DATA_ROOT=data

# ── Profiling flags ───────────────────────────────────────────────────────────
# Set to 1 to auto-trigger deep profiling when overhead > 15%
AUTO_PROFILE=1
PROFILE_OVERHEAD_THRESHOLD=0.15
