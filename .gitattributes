# Git LFS — large binary / CSV files tracked by pointer, not content.
# Set up LFS with: git lfs install && git lfs track "data/raw/*.csv"

# Raw experiment output (never edited, can be large)
results/**/*.out filter=lfs diff=lfs merge=lfs -text
results/**/*.nsys-rep filter=lfs diff=lfs merge=lfs -text
results/**/*.ncu-rep filter=lfs diff=lfs merge=lfs -text

# Raw data CSVs (append-only; can grow to hundreds of MB)
data/raw/*.csv filter=lfs diff=lfs merge=lfs -text

# Container images (if ever committed)
*.sif filter=lfs diff=lfs merge=lfs -text
*.img filter=lfs diff=lfs merge=lfs -text

# Line endings — enforce Unix on all text files
* text=auto eol=lf
*.sh text eol=lf
*.py text eol=lf
*.tex text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.bib text eol=lf
*.csv text eol=lf

# Binary — no diff
*.png binary
*.pdf binary
*.sif binary
