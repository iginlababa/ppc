#!/usr/bin/env bash
# stream-amdgpu — wrapper that invokes kernel_stream_amdgpu.jl via Julia 1.12+.
#
# Requires Julia >= 1.12 (LLVM 18, gfx942 support) + AMDGPU.jl >= 2.0.
# The juliaup rc channel (julia+rc) is used if the default julia is < 1.12.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JL_SCRIPT="${SCRIPT_DIR}/kernel_stream_amdgpu.jl"

# Prefer julia+rc (1.12) which has LLVM 18 / gfx942 support.
# Fall back to whatever julia is on PATH.
if command -v julia &>/dev/null; then
    JULIA_BIN="julia"
else
    echo "ERROR: julia not found on PATH" >&2
    exit 1
fi

exec "${JULIA_BIN}" --startup-file=no "${JL_SCRIPT}" "$@"
